---
import Layout from '../../../layouts/Layout.astro';

// Dữ liệu các Part
const listeningParts = [
  { id: 1, title: "Part 1", desc: "Mô tả hình ảnh", icon: "📸" },
  { id: 2, title: "Part 2", desc: "Hỏi & Đáp", icon: "❓" },
  { id: 3, title: "Part 3", desc: "Đoạn hội thoại", icon: "👥" },
  { id: 4, title: "Part 4", desc: "Bài nói ngắn", icon: "📢" },
];

const readingParts = [
  { id: 5, title: "Part 5", desc: "Điền vào câu", icon: "📝" },
  { id: 6, title: "Part 6", desc: "Điền vào đoạn văn", icon: "📄" },
  { id: 7, title: "Part 7", desc: "Đọc hiểu đoạn văn", icon: "📚" },
];

const practiceTools = [
  { title: "Ôn từ vựng", icon: "📔", link: "/english-lab/toeic/flashcards" },
  { title: "Khóa học", icon: "🎓", link: "#" },
  { title: "Luyện nghe", icon: "🎧", link: "/english-lab/toeic/dictation" },
  { title: "Lộ trình", icon: "🗺️", link: "#" },
  { title: "Học cụm từ", icon: "💬", link: "#" },
  { title: "Thi thử", icon: "🏆", link: "/english-lab/toeic/exam-test", hot: true },
];
---

<Layout title="TOEIC Dashboard | Learn Lab">
  <div class="bg-teal-600 py-3 text-center text-white font-bold shadow-md">
    TOEIC® MASTER DASHBOARD
  </div>

  <main class="min-h-screen bg-slate-100 p-4 lg:p-8">
    <div class="mx-auto max-w-[1600px] flex flex-col lg:flex-row gap-8">
      
      <div class="flex-1 space-y-6">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="rounded-2xl border border-teal-100 bg-white p-4 flex items-center justify-between shadow-sm">
            <span class="flex items-center gap-2 font-bold text-teal-700">
              <span class="text-xl">👑</span> Tài khoản: VIP Trọn đời
            </span>
          </div>
          <div class="rounded-2xl bg-white p-4 shadow-sm flex items-center justify-around text-center">
            <div>
              <p class="text-[10px] font-bold text-slate-400">HOÀN THÀNH</p>
              <p class="font-black text-teal-600">2%</p>
            </div>
            <div class="h-10 w-px bg-slate-100"></div>
            <div>
              <p class="text-[10px] font-bold text-slate-400">TỶ LỆ ĐÚNG</p>
              <p class="font-black text-teal-600">93%</p>
            </div>
            <button class="bg-teal-500 text-white text-xs px-4 py-2 rounded-full font-bold hover:bg-teal-600 transition">Tiếp tục học</button>
          </div>
        </div>

        <div class="rounded-2xl bg-gradient-to-r from-teal-400 to-emerald-500 p-6 text-white flex justify-between items-center shadow-lg">
          <div>
            <p class="text-xs font-bold opacity-80">Thi thử online tuần: 13 - 2026</p>
            <h3 class="text-xl font-black mt-1">100 câu hỏi • 60 phút</h3>
          </div>
          <div class="flex gap-3">
            <a href="/english-lab/toeic/exam-test" class="bg-amber-400 text-slate-900 px-6 py-2 rounded-lg font-black text-sm hover:bg-amber-300">Tham gia</a>
            <button class="bg-white/20 px-4 py-2 rounded-lg font-bold text-sm backdrop-blur-sm">Bảng xếp hạng</button>
          </div>
        </div>

        <div>
          <h2 class="text-sm font-black text-slate-400 mb-4 uppercase tracking-widest">Nghe hiểu</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {listeningParts.map(part => (
              <a href="#" class="bg-white p-6 rounded-2xl border border-slate-100 text-center shadow-sm hover:border-teal-300 transition group">
                <div class="text-3xl mb-3 group-hover:scale-110 transition-transform">{part.icon}</div>
                <p class="font-black text-slate-800 text-sm">{part.title}</p>
                <p class="text-[10px] text-slate-400 font-medium">{part.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-sm font-black text-slate-400 mb-4 uppercase tracking-widest">Đọc hiểu</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {readingParts.map(part => (
              <a href="#" class="bg-white p-6 rounded-2xl border border-slate-100 text-center shadow-sm hover:border-teal-300 transition group">
                <div class="text-3xl mb-3 group-hover:scale-110 transition-transform">{part.icon}</div>
                <p class="font-black text-slate-800 text-sm">{part.title}</p>
                <p class="text-[10px] text-slate-400 font-medium">{part.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-sm font-black text-slate-400 mb-4 uppercase tracking-widest">Luyện tập</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {practiceTools.map(tool => (
              <a href={tool.link} class="bg-white p-5 rounded-xl border border-slate-100 text-center shadow-sm hover:shadow-md transition relative overflow-hidden">
                {tool.hot && <span class="absolute top-0 right-0 bg-rose-500 text-[8px] text-white px-2 py-0.5 font-bold">HOT</span>}
                <div class="text-2xl mb-2">{tool.icon}</div>
                <p class="font-bold text-slate-700 text-xs">{tool.title}</p>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="w-full lg:w-[450px] space-y-6">
        <div class="rounded-3xl bg-white p-8 shadow-sm border border-slate-100">
          <h2 class="text-center font-black text-teal-700 mb-8">Cấu trúc đề thi Toeic 2 kỹ năng (LR)</h2>
          
          <div class="space-y-4 mb-10">
            <div class="bg-slate-100 py-2 rounded-lg text-center font-bold text-slate-600 text-sm">Phần nghe (100 câu - 45 phút)</div>
            <div class="flex gap-1 h-12">
              <div class="flex-1 bg-slate-500 rounded-l-lg flex items-center justify-center text-[10px] text-white font-bold">P1</div>
              <div class="flex-[3] bg-teal-500 flex items-center justify-center text-[10px] text-white font-bold">P2</div>
              <div class="flex-[4] bg-orange-400 flex items-center justify-center text-[10px] text-white font-bold">P3</div>
              <div class="flex-[3] bg-rose-500 rounded-r-lg flex items-center justify-center text-[10px] text-white font-bold">P4</div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="border-2 border-dashed border-slate-200 p-3 rounded-xl text-center">
                <p class="text-[10px] font-black text-slate-400">Mô tả hình ảnh</p>
                <p class="text-[9px] text-slate-400 leading-tight mt-1">Nhìn hình, nghe 4 lựa chọn chọn đáp án đúng.</p>
              </div>
              <div class="border-2 border-dashed border-slate-200 p-3 rounded-xl text-center">
                <p class="text-[10px] font-black text-slate-400">Đoạn hội thoại</p>
                <p class="text-[9px] text-slate-400 leading-tight mt-1">Nghe đoạn thoại, mỗi đoạn có 3 câu hỏi.</p>
              </div>
            </div>
          </div>

          <div class="space-y-4">
            <div class="bg-slate-100 py-2 rounded-lg text-center font-bold text-slate-600 text-sm">Phần đọc (100 câu - 75 phút)</div>
            <div class="flex gap-1 h-12">
              <div class="flex-[3] bg-emerald-500 rounded-l-lg flex items-center justify-center text-[10px] text-white font-bold">P5</div>
              <div class="flex-[2] bg-amber-400 flex items-center justify-center text-[10px] text-white font-bold">P6</div>
              <div class="flex-[5] bg-rose-400 rounded-r-lg flex items-center justify-center text-[10px] text-white font-bold">P7</div>
            </div>
            <div class="border-2 border-dashed border-rose-200 bg-rose-50/30 p-4 rounded-xl text-center">
              <p class="text-[10px] font-black text-rose-600 uppercase">Đọc hiểu đoạn văn</p>
              <p class="text-[9px] text-slate-500 mt-1 italic">Đây là phần chiếm điểm cao nhất và tốn thời gian nhất (54 câu).</p>
            </div>
          </div>

          <div class="mt-8 p-4 bg-amber-50 rounded-xl border border-amber-100">
            <p class="text-[10px] font-black text-amber-700 mb-2">QUAN TRỌNG:</p>
            <ul class="text-[9px] text-amber-800 space-y-1 list-decimal pl-4">
              <li>Hệ thống tự động phát âm thanh, không được dừng.</li>
              <li>Hết thời gian hệ thống sẽ tự nộp bài.</li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </main>
</Layout>