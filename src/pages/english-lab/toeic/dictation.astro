---
import Layout from '../../../layouts/Layout.astro';

const topics = [
  {
    id: 'office',
    title: 'Office & Meetings',
    description: 'Từ vựng văn phòng và cuộc họp',
    color: 'teal',
    sentences: [
      'The meeting will be held in the conference room.',
      'Please submit your report before the deadline.',
      'The manager reviewed the quarterly financial report.',
      'All employees are required to attend the training session.',
      'The office will be closed on public holidays.',
      'Could you please reschedule the meeting for next Monday?',
      'The project deadline has been extended by two weeks.',
      'Please make sure to copy all team members on the email.',
      'The new policy will take effect from the first of next month.',
      'We need to finalize the agenda before the board meeting.'
    ]
  },
  {
    id: 'finance',
    title: 'Finance & Accounting',
    description: 'Từ vựng tài chính và kế toán',
    color: 'sky',
    sentences: [
      'The invoice must be paid within thirty days.',
      'Our company reported a significant increase in annual revenue.',
      'The budget for next quarter has been approved.',
      'Please send the financial statement to the accounting department.',
      'The bank transfer was processed successfully this morning.',
      'All expenses must be submitted with original receipts.',
      'The quarterly profit exceeded our initial forecast.',
      'We need to reduce operational costs by ten percent.',
      'The audit report will be ready by the end of the week.',
      'Please review the attached spreadsheet before the meeting.'
    ]
  },
  {
    id: 'hr',
    title: 'HR & Recruitment',
    description: 'Từ vựng nhân sự và tuyển dụng',
    color: 'emerald',
    sentences: [
      'We are looking for a qualified candidate for this position.',
      'Please send your resume and cover letter by Friday.',
      'The interview will be conducted via video conference.',
      'All new employees must complete the onboarding program.',
      'The performance review will be held at the end of the year.',
      'Employees are entitled to fifteen days of annual leave.',
      'The job description has been updated on our website.',
      'We offer competitive salaries and excellent benefits.',
      'The training workshop will last for two full days.',
      'Please contact the HR department for more information.'
    ]
  }
];
---

<Layout title="TOEIC Dictation | Learn Lab">
  <main class="min-h-screen bg-teal-50/40 px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <section class="mx-auto max-w-3xl">

      <!-- Topic picker -->
      <div id="topic-picker">
        <div class="rounded-[28px] border border-teal-100 bg-white px-6 py-8 shadow-sm sm:px-8">
          <p class="text-sm font-bold uppercase tracking-[0.3em] text-teal-600">TOEIC Dictation</p>
          <h1 class="mt-3 text-3xl font-extrabold text-slate-900 sm:text-4xl">Chọn chủ đề</h1>
          <p class="mt-3 text-base leading-7 text-slate-600">
            Mỗi chủ đề có 10 câu. Nghe → Gõ lại → Kiểm tra → Next.
          </p>
        </div>

        <div class="mt-4 flex flex-col gap-4">
          {topics.map((topic) => (
            <button
              class="topic-card text-left rounded-[24px] border border-slate-100 bg-white px-6 py-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
              data-topic={topic.id}
            >
              <p class={`text-sm font-semibold ${
                topic.color === 'teal' ? 'text-teal-600' :
                topic.color === 'sky' ? 'text-sky-600' : 'text-emerald-600'
              }`}>{topic.title}</p>
              <p class="mt-1 text-base font-bold text-slate-900">{topic.description}</p>
              <p class="mt-1 text-sm text-slate-500">{topic.sentences.length} câu</p>
            </button>
          ))}
        </div>
      </div>

      <!-- Practice view -->
      <div id="practice-view" class="hidden">

        <div class="flex items-center justify-between gap-4">
          <button id="back-btn" class="inline-flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
            ← Chủ đề khác
          </button>
          <span id="progress-label" class="text-sm font-semibold text-slate-500"></span>
        </div>

        <!-- Progress bar -->
        <div class="mt-4 h-2 w-full rounded-full bg-slate-100">
          <div id="progress-bar" class="h-2 rounded-full bg-teal-500 transition-all duration-500" style="width: 0%"></div>
        </div>

        <!-- Streak banner -->
        <div id="streak-banner" class="hidden mt-4 rounded-2xl bg-orange-50 border border-orange-100 px-5 py-3 flex items-center gap-3">
          <span class="text-xl">🔥</span>
          <span id="streak-text" class="text-sm font-bold text-orange-600"></span>
        </div>

        <div class="mt-4 rounded-[28px] border border-teal-100 bg-white px-6 py-8 shadow-sm sm:px-8">

          <div class="flex items-center justify-between">
            <p id="topic-label" class="text-sm font-bold uppercase tracking-[0.3em] text-teal-600"></p>
            <span id="level-badge" class="text-xs font-semibold text-slate-400"></span>
          </div>

          <h2 class="mt-4 text-lg font-bold text-slate-900">Nghe và gõ lại câu bạn nghe được</h2>
          <p class="mt-1 text-xs text-slate-400">Ctrl để nghe lại · Enter để kiểm tra</p>

          <!-- Play + speed controls -->
          <div class="mt-6 flex flex-wrap items-center gap-3">
            <button id="play-btn" class="inline-flex items-center gap-2 rounded-2xl bg-teal-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-teal-600">
              ▶ Phát câu
            </button>

            <div class="flex items-center gap-1 rounded-2xl border border-slate-200 bg-slate-50 p-1">
              <button data-speed="0.5" class="speed-btn rounded-xl px-3 py-1.5 text-xs font-semibold text-slate-500 transition hover:bg-white hover:text-slate-800">0.5x</button>
              <button data-speed="0.75" class="speed-btn rounded-xl px-3 py-1.5 text-xs font-semibold text-slate-500 transition hover:bg-white hover:text-slate-800">0.75x</button>
              <button data-speed="1" class="speed-btn active-speed rounded-xl bg-white px-3 py-1.5 text-xs font-semibold text-slate-800 shadow-sm transition">1x</button>
            </div>

            <span class="text-xs text-slate-400">Ctrl nghe lại</span>
          </div>

          <!-- Word slots -->
          <div class="mt-8">
            <div id="word-slots" class="flex flex-wrap gap-x-5 gap-y-5 pb-2"></div>
          </div>

          <!-- Actions -->
          <div class="mt-6 flex flex-wrap items-center gap-3">
            <button id="check-btn" class="inline-flex rounded-2xl bg-slate-800 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700">
              Kiểm tra
            </button>
            <button id="show-btn" class="inline-flex rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-600 transition hover:bg-slate-50">
              Xem đáp án
            </button>
            <button id="reset-btn" class="inline-flex rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-600 transition hover:bg-slate-50">
              Làm lại
            </button>
          </div>

          <div id="result-box" class="hidden mt-5 rounded-2xl bg-slate-50 px-5 py-4 text-sm leading-8"></div>
          <div id="score-box" class="hidden mt-3 text-sm font-semibold"></div>

          <div id="next-wrap" class="hidden mt-6 border-t border-slate-100 pt-6">
            <button id="next-btn" class="inline-flex w-full items-center justify-center rounded-2xl bg-teal-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-teal-600">
              Câu tiếp theo →
            </button>
          </div>
        </div>
      </div>

      <!-- Done screen -->
      <div id="done-screen" class="hidden rounded-[28px] border border-emerald-100 bg-emerald-50 px-6 py-10 text-center shadow-sm">
        <p class="text-sm font-bold uppercase tracking-[0.3em] text-emerald-600">Hoàn thành</p>
        <h2 class="mt-3 text-3xl font-extrabold text-slate-900">Bạn đã luyện xong chủ đề này!</h2>
        <p id="final-score" class="mt-4 text-lg font-semibold text-slate-700"></p>
        <p id="best-streak" class="mt-2 text-sm font-semibold text-orange-500"></p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
          <button id="retry-btn" class="inline-flex items-center justify-center rounded-2xl bg-teal-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-teal-600">
            Luyện lại chủ đề này
          </button>
          <button id="home-btn" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
            Chọn chủ đề khác
          </button>
        </div>
      </div>

    </section>
  </main>
</Layout>

<script define:vars={{ topics }}>
  let currentTopic  = null;
  let currentIndex  = 0;
  let totalCorrect  = 0;
  let totalWords    = 0;
  let typedValue    = '';
  let isChecked     = false;
  let currentSpeed  = 1;
  let streak        = 0;
  let bestStreak    = 0;

  const topicPicker   = document.getElementById('topic-picker');
  const practiceView  = document.getElementById('practice-view');
  const doneScreen    = document.getElementById('done-screen');
  const progressLabel = document.getElementById('progress-label');
  const progressBar   = document.getElementById('progress-bar');
  const topicLabel    = document.getElementById('topic-label');
  const levelBadge    = document.getElementById('level-badge');
  const playBtn       = document.getElementById('play-btn');
  const checkBtn      = document.getElementById('check-btn');
  const showBtn       = document.getElementById('show-btn');
  const resetBtn      = document.getElementById('reset-btn');
  const nextBtn       = document.getElementById('next-btn');
  const nextWrap      = document.getElementById('next-wrap');
  const backBtn       = document.getElementById('back-btn');
  const retryBtn      = document.getElementById('retry-btn');
  const homeBtn       = document.getElementById('home-btn');
  const wordSlots     = document.getElementById('word-slots');
  const resultBox     = document.getElementById('result-box');
  const scoreBox      = document.getElementById('score-box');
  const finalScore    = document.getElementById('final-score');
  const bestStreakEl  = document.getElementById('best-streak');
  const streakBanner  = document.getElementById('streak-banner');
  const streakText    = document.getElementById('streak-text');

  // ── Speech ────────────────────────────────────────────────────
  function speak(text, onEnd) {
    window.speechSynthesis.cancel();
    const utter  = new SpeechSynthesisUtterance(text);
    utter.lang   = 'en-US';
    utter.rate   = currentSpeed;
    if (onEnd) utter.onend = onEnd;
    window.speechSynthesis.speak(utter);
  }

  // ── Speed buttons ─────────────────────────────────────────────
  document.querySelectorAll('.speed-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentSpeed = parseFloat(btn.dataset.speed);
      document.querySelectorAll('.speed-btn').forEach(b => {
        b.classList.remove('active-speed', 'bg-white', 'text-slate-800', 'shadow-sm');
        b.classList.add('text-slate-500');
      });
      btn.classList.add('active-speed', 'bg-white', 'text-slate-800', 'shadow-sm');
      btn.classList.remove('text-slate-500');
    });
  });

  // ── Streak ────────────────────────────────────────────────────
  function updateStreak(isPerfect) {
    if (isPerfect) {
      streak++;
      if (streak > bestStreak) bestStreak = streak;
      if (streak >= 2) {
        streakText.textContent = `${streak} câu đúng liên tiếp! Tuyệt vời!`;
        streakBanner.classList.remove('hidden');
      }
    } else {
      streak = 0;
      streakBanner.classList.add('hidden');
    }
  }

  // ── Word slots ────────────────────────────────────────────────
  function buildWordSlots(text) {
    const words = text.replace(/[^a-zA-Z0-9\s]/g, '').split(/\s+/);
    wordSlots.innerHTML = '';

    words.forEach((word) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'flex flex-col items-start gap-1';
      wrapper.dataset.word = word.toLowerCase();

      const display = document.createElement('div');
      display.className = 'word-display min-h-[24px] text-base font-semibold tracking-wide text-slate-300';

      const bars = document.createElement('div');
      bars.className = 'flex gap-[3px]';

      for (let j = 0; j < word.length; j++) {
        const bar = document.createElement('div');
        bar.className = 'letter-bar h-[3px] w-[9px] rounded-full bg-slate-200 transition-all duration-150';
        bars.appendChild(bar);
      }

      wrapper.appendChild(display);
      wrapper.appendChild(bars);
      wordSlots.appendChild(wrapper);
    });

    updateDisplay('');
  }

  function updateDisplay(value) {
    const typedWords = value.trimStart().split(' ');
    const slots = document.querySelectorAll('#word-slots > div');

    slots.forEach((slot, i) => {
      const display = slot.querySelector('.word-display');
      const bars    = slot.querySelectorAll('.letter-bar');
      const target  = slot.dataset.word ?? '';
      const typed   = (typedWords[i] ?? '').toLowerCase().replace(/[^a-z0-9]/g, '');

      display.textContent = typedWords[i] ?? '';

      // Real-time highlight: nếu đã gõ xong từ (có space sau) thì check ngay
      const wordDone = i < typedWords.length - 1;

      if (value.trim() === '') {
        display.className = 'word-display min-h-[24px] text-base font-semibold tracking-wide text-slate-300';
      } else if (wordDone) {
        const isCorrect = typed === target;
        display.className = `word-display min-h-[24px] text-base font-semibold tracking-wide ${isCorrect ? 'text-emerald-500' : 'text-red-400'}`;
      } else if (i === typedWords.length - 1) {
        display.className = 'word-display min-h-[24px] text-base font-semibold tracking-wide text-teal-500';
      } else {
        display.className = 'word-display min-h-[24px] text-base font-semibold tracking-wide text-slate-300';
      }

      // Gạch màu
      bars.forEach((bar, j) => {
        bar.classList.remove('bg-slate-200', 'bg-teal-400', 'bg-emerald-400', 'bg-red-400');
        if (wordDone) {
          bar.classList.add(typed === target ? 'bg-emerald-400' : 'bg-red-400');
        } else {
          bar.classList.add(j < typed.length ? 'bg-teal-400' : 'bg-slate-200');
        }
      });
    });
  }

  function finaliseDisplay(value) {
    const typedWords = value.trim().split(/\s+/);
    const slots = document.querySelectorAll('#word-slots > div');

    slots.forEach((slot, i) => {
      const display   = slot.querySelector('.word-display');
      const bars      = slot.querySelectorAll('.letter-bar');
      const target    = slot.dataset.word ?? '';
      const typed     = (typedWords[i] ?? '').toLowerCase().replace(/[^a-z0-9]/g, '');
      const isCorrect = typed === target;

      display.className = `word-display min-h-[24px] text-base font-semibold tracking-wide ${isCorrect ? 'text-emerald-600' : 'text-red-500'}`;

      bars.forEach((bar) => {
        bar.classList.remove('bg-slate-200', 'bg-teal-400', 'bg-emerald-400', 'bg-red-400');
        bar.classList.add(isCorrect ? 'bg-emerald-400' : 'bg-red-400');
      });
    });
  }

  // ── Check answer ──────────────────────────────────────────────
  function normalise(str) {
    return str.toLowerCase().replace(/[^a-z0-9\s]/g, '').trim();
  }

  function checkAnswer(original, userInput) {
    const origWords  = normalise(original).split(/\s+/);
    const inputWords = normalise(userInput).split(/\s+/);
    let correct = 0;

    const html = origWords.map((word, i) => {
      const userWord = inputWords[i] ?? '';
      if (userWord === word) {
        correct++;
        return `<span class="rounded px-1 bg-emerald-100 text-emerald-800 font-semibold">${word}</span>`;
      } else {
        return `<span class="rounded px-1 bg-red-100 text-red-700 font-semibold" title="Bạn gõ: ${userWord || '(trống)'}">${word}</span>`;
      }
    }).join(' ');

    return { html, correct, total: origWords.length };
  }

  // ── Load / start ──────────────────────────────────────────────
  function loadSentence() {
    const total = currentTopic.sentences.length;
    progressLabel.textContent = `Câu ${currentIndex + 1} / ${total}`;
    progressBar.style.width   = `${(currentIndex / total) * 100}%`;
    topicLabel.textContent    = currentTopic.title;
    levelBadge.textContent    = `Câu ${currentIndex + 1}`;

    typedValue = '';
    isChecked  = false;

    resultBox.classList.add('hidden');
    scoreBox.classList.add('hidden');
    nextWrap.classList.add('hidden');
    playBtn.textContent = '▶ Phát câu';
    playBtn.disabled    = false;

    buildWordSlots(currentTopic.sentences[currentIndex]);
  }

  function startTopic(topicId) {
    currentTopic = topics.find(t => t.id === topicId);
    currentIndex = 0;
    totalCorrect = 0;
    totalWords   = 0;
    streak       = 0;
    bestStreak   = 0;

    streakBanner.classList.add('hidden');
    topicPicker.classList.add('hidden');
    doneScreen.classList.add('hidden');
    practiceView.classList.remove('hidden');

    loadSentence();
  }

  function showDone() {
    practiceView.classList.add('hidden');
    doneScreen.classList.remove('hidden');
    const pct = totalWords > 0 ? Math.round((totalCorrect / totalWords) * 100) : 0;
    finalScore.textContent    = `Độ chính xác tổng: ${totalCorrect}/${totalWords} từ — ${pct}%`;
    bestStreakEl.textContent   = bestStreak >= 2 ? `🔥 Streak tốt nhất: ${bestStreak} câu liên tiếp` : '';
    progressBar.style.width   = '100%';
  }

  // ── Keyboard ──────────────────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    if (!practiceView || practiceView.classList.contains('hidden')) return;

    if ([' ', 'Tab', 'ArrowUp', 'ArrowDown'].includes(e.key)) {
      e.preventDefault();
    }

    if (isChecked) {
      if (e.key === 'Enter') { e.preventDefault(); nextBtn.click(); }
      return;
    }

    if (e.key === 'Control') {
      e.preventDefault();
      speak(currentTopic.sentences[currentIndex]);
      return;
    }

    if (e.key === 'Enter') {
      e.preventDefault();
      checkBtn.click();
      return;
    }

    if (e.key === 'Backspace') {
      typedValue = typedValue.slice(0, -1);
      updateDisplay(typedValue);
      return;
    }

    if (e.key.length === 1) {
      if (e.key === ' ' && typedValue.endsWith(' ')) return;
      typedValue += e.key;
      updateDisplay(typedValue);
    }
  });

  // ── Button events ─────────────────────────────────────────────
  document.querySelectorAll('.topic-card').forEach(card => {
    card.addEventListener('click', () => startTopic(card.dataset.topic));
  });

  playBtn.addEventListener('click', () => {
    const text = currentTopic.sentences[currentIndex];
    playBtn.textContent = '⏸ Đang phát...';
    playBtn.disabled    = true;
    speak(text, () => {
      playBtn.textContent = '▶ Phát lại';
      playBtn.disabled    = false;
    });
  });

  checkBtn.addEventListener('click', () => {
    if (!typedValue.trim() || isChecked) return;
    isChecked = true;

    const { html, correct, total } = checkAnswer(currentTopic.sentences[currentIndex], typedValue);
    totalCorrect += correct;
    totalWords   += total;

    const isPerfect = correct === total;
    updateStreak(isPerfect);
    finaliseDisplay(typedValue);

    resultBox.innerHTML = html;
    resultBox.classList.remove('hidden');

    const pct   = Math.round((correct / total) * 100);
    const color = pct === 100 ? 'text-emerald-600' : pct >= 60 ? 'text-amber-600' : 'text-red-600';
    scoreBox.innerHTML = `<span class="${color}">${pct === 100 ? '🎉 ' : ''}Đúng ${correct}/${total} từ — ${pct}%</span>`;
    scoreBox.classList.remove('hidden');
    nextWrap.classList.remove('hidden');
  });

  showBtn.addEventListener('click', () => {
    const text = currentTopic.sentences[currentIndex];
    resultBox.innerHTML = text.split(' ').map(w =>
      `<span class="rounded px-1 bg-slate-200 text-slate-700">${w}</span>`
    ).join(' ');
    resultBox.classList.remove('hidden');
    nextWrap.classList.remove('hidden');
    streak = 0;
    streakBanner.classList.add('hidden');
  });

  resetBtn.addEventListener('click', () => {
    typedValue = '';
    isChecked  = false;
    resultBox.classList.add('hidden');
    scoreBox.classList.add('hidden');
    nextWrap.classList.add('hidden');
    window.speechSynthesis.cancel();
    updateDisplay('');
  });

  nextBtn.addEventListener('click', () => {
    currentIndex++;
    if (currentIndex >= currentTopic.sentences.length) {
      showDone();
    } else {
      loadSentence();
    }
  });

  backBtn.addEventListener('click', () => {
    window.speechSynthesis.cancel();
    streakBanner.classList.add('hidden');
    practiceView.classList.add('hidden');
    topicPicker.classList.remove('hidden');
  });

  retryBtn.addEventListener('click', () => startTopic(currentTopic.id));

  homeBtn.addEventListener('click', () => {
    doneScreen.classList.add('hidden');
    topicPicker.classList.remove('hidden');
  });
</script>
