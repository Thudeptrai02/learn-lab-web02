---
import Layout from '../../../layouts/Layout.astro';

// ==========================================
// 1. XỬ LÝ LẤY NGÀY THÁNG TỰ ĐỘNG (LIVE DATE)
// ==========================================
const today = new Date();

// Format hàm để ra chuẩn yyyy/mm/dd
const formatDate = (dateObj) => {
  const yyyy = dateObj.getFullYear();
  const mm = String(dateObj.getMonth() + 1).padStart(2, '0');
  const dd = String(dateObj.getDate()).padStart(2, '0');
  return `${yyyy}/${mm}/${dd}`;
};

const liveTestDate = formatDate(today);

// Tính ngày hết hạn (Cộng thêm exactly 2 năm)
const expiryDate = new Date(today);
expiryDate.setFullYear(expiryDate.getFullYear() + 2);
const liveValidUntil = formatDate(expiryDate);


// ==========================================
// 2. MÔ PHỎNG DỮ LIỆU TỪ DATABASE
// ==========================================
const student = {
  // Sau này bạn thay chuỗi này bằng biến lấy từ Session/DB (VD: user.fullName)
  name: "Tên Tài Khoản (Đang chờ DB)", 
  idNumber: "TOEIC-2026-LIVE",
  dob: "2000/01/01", // Mốc cố định năm 2000
  testDate: liveTestDate,
  validUntil: liveValidUntil,
  listening: 430, // Thử đổi số này để xem thanh chạy (5 - 495)
  reading: 410,   // Thử đổi số này để xem thanh chạy (5 - 495)
};

const totalScore = student.listening + student.reading;


// ==========================================
// 3. THUẬT TOÁN TÍNH TỶ LỆ THANH ĐIỂM
// ==========================================
// Điểm TOEIC tối thiểu là 5, tối đa là 495.
// Công thức: ((Điểm - 5) / (495 - 5)) * 100
const getPosition = (score) => {
  const safeScore = Math.min(Math.max(score, 5), 495); // Ép điểm luôn nằm trong khoảng 5-495
  return ((safeScore - 5) / 490) * 100;
};

const posL = getPosition(student.listening);
const posR = getPosition(student.reading);
