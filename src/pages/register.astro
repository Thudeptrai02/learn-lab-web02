---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Đăng ký | Learn Lab">
  <main class="flex min-h-[calc(100vh-80px)] w-full bg-white">
    
    <div class="flex w-full flex-col justify-center px-6 py-10 lg:w-1/2 lg:px-20 xl:px-32">
      <div class="mx-auto w-full max-w-sm">
        
        <div class="mb-8 text-center lg:text-left">
          <h1 class="text-3xl font-black text-slate-900 tracking-tight">Bắt đầu hành trình! 🚀</h1>
          <p class="mt-2 text-sm font-medium text-slate-500">
            Tạo tài khoản miễn phí để mở khóa toàn bộ kho tàng kiến thức của Learn Lab.
          </p>
        </div>

        <div class="mt-6 flex flex-col gap-3">
          <button class="flex w-full items-center justify-center gap-3 rounded-xl border-2 border-slate-200 bg-white px-4 py-3.5 text-sm font-bold text-slate-700 shadow-sm transition-all hover:bg-slate-50 hover:border-slate-300 active:scale-[0.98]">
            <svg class="h-5 w-5" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Đăng ký bằng Google
          </button>

          <button class="flex w-full items-center justify-center gap-3 rounded-xl bg-[#1877F2] px-4 py-3.5 text-sm font-bold text-white shadow-sm transition-all hover:bg-[#166FE5] active:scale-[0.98]">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
            </svg>
            Đăng ký bằng Facebook
          </button>
        </div>

        <div class="relative mt-7 mb-7">
          <div class="absolute inset-0 flex items-center" aria-hidden="true">
            <div class="w-full border-t border-slate-200"></div>
          </div>
          <div class="relative flex justify-center text-sm font-medium leading-6">
            <span class="bg-white px-4 text-slate-400">Hoặc đăng ký bằng Email</span>
          </div>
        </div>

        <form action="#" method="POST" class="space-y-4">
          <div>
            <label for="fullname" class="block text-sm font-bold text-slate-700">Họ và tên</label>
            <div class="mt-1.5">
              <input id="fullname" name="fullname" type="text" required placeholder="Nguyễn Văn A" class="block w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-teal-500 focus:outline-none focus:ring-4 focus:ring-teal-50 transition-all sm:text-sm font-medium" />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-bold text-slate-700">Email</label>
            <div class="mt-1.5">
              <input id="email" name="email" type="email" autocomplete="email" required placeholder="ví dụ: hocvien@learnlab.com" class="block w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-teal-500 focus:outline-none focus:ring-4 focus:ring-teal-50 transition-all sm:text-sm font-medium" />
            </div>
          </div>

          <div>
            <label for="password" class="block text-sm font-bold text-slate-700">Mật khẩu</label>
            <div class="mt-1.5 relative">
              <input id="password" name="password" type="password" required placeholder="Tạo mật khẩu (tối thiểu 8 ký tự)" class="block w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-teal-500 focus:outline-none focus:ring-4 focus:ring-teal-50 transition-all sm:text-sm font-medium" />
            </div>
          </div>

          <div>
            <label for="confirm-password" class="block text-sm font-bold text-slate-700">Nhập lại mật khẩu</label>
            <div class="mt-1.5 relative">
              <input id="confirm-password" name="confirm-password" type="password" required placeholder="Xác nhận lại mật khẩu" class="block w-full rounded-xl border-2 border-slate-200 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-teal-500 focus:outline-none focus:ring-4 focus:ring-teal-50 transition-all sm:text-sm font-medium" />
            </div>
          </div>

          <div class="pt-3">
            <button type="submit" class="flex w-full justify-center rounded-xl bg-teal-600 px-4 py-4 text-sm font-bold text-white shadow-lg shadow-teal-200 transition-all hover:bg-teal-700 hover:-translate-y-0.5 active:scale-[0.98]">
              Tạo tài khoản Learn Lab
            </button>
            <p class="mt-3 text-center text-xs font-medium text-slate-500">
              Bằng việc đăng ký, bạn đồng ý với <a href="#" class="font-bold text-teal-600 hover:text-teal-500">Điều khoản dịch vụ</a> và <a href="#" class="font-bold text-teal-600 hover:text-teal-500">Chính sách bảo mật</a> của chúng tôi.
            </p>
          </div>
        </form>

        <p class="mt-8 text-center text-sm font-medium text-slate-600">
          Đã có tài khoản?
          <a href="/login" class="font-bold text-teal-600 hover:text-teal-500 transition-colors">Đăng nhập ngay</a>
        </p>

      </div>
    </div>

    <div class="relative hidden w-1/2 lg:block overflow-hidden">
      <img 
        class="absolute inset-0 h-full w-full object-cover" 
        src="https://images.unsplash.com/photo-1434030216411-0b793f4b4173?q=80&w=2070&auto=format&fit=crop" 
        alt="Góc học tập truyền cảm hứng" 
      />
      <div class="absolute inset-0 bg-teal-900/75 mix-blend-multiply"></div>
      
      <div class="absolute inset-0 flex flex-col justify-between p-16 text-white">
        <div class="inline-flex w-fit items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-bold backdrop-blur-md">
          🔥 Gia nhập cộng đồng 10,000+ Học viên
        </div>

        <div class="max-w-md">
          <blockquote class="text-3xl font-bold leading-snug">
            "Giáo dục là vũ khí mạnh nhất mà bạn có thể dùng để thay đổi thế giới."
          </blockquote>
          <p class="mt-4 text-lg font-medium text-teal-100">
            — Nelson Mandela
          </p>
        </div>
      </div>
    </div>

  </main>
</Layout>