---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} — Learn Lab`}>
  <main class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <a href="/blog" class="text-sm font-semibold text-teal-600 hover:text-teal-700">← Quay lại Blog</a>
    <h1 class="mt-6 text-3xl font-extrabold text-slate-900">{post.data.title}</h1>
    {post.data.date && (
      <p class="mt-2 text-sm text-slate-400">{new Date(post.data.date).toLocaleDateString('vi-VN')}</p>
    )}
    <div class="mt-8 prose prose-slate max-w-none">
      <Content />
    </div>
  </main>
</Layout>
