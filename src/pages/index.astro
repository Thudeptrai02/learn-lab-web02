---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Learn Lab — Học tiếng Anh rõ ràng, có hệ thống">
  <main>

    <!-- ── Hero ── -->
    <section class="relative overflow-hidden bg-white px-4 pt-16 pb-20 sm:px-6 lg:px-8 lg:pt-24 lg:pb-28">
      <div class="pointer-events-none absolute -top-32 -left-32 h-[500px] w-[500px] rounded-full bg-teal-100/50 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-32 -right-32 h-[400px] w-[400px] rounded-full bg-sky-100/50 blur-3xl"></div>

      <div class="relative mx-auto max-w-5xl text-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-teal-100 bg-teal-50 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.25em] text-teal-600">
          ✦ Miễn phí hoàn toàn · Không cần đăng ký
        </span>

        <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
          Học tiếng Anh<br class="hidden sm:block" />
          <span class="text-teal-500">rõ ràng và có hệ thống</span>
        </h1>

        <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-slate-500 sm:text-lg">
          Flashcard, Dictation và bài luyện TOEIC · IELTS · Cambridge — được thiết kế để bạn học được thật, không chỉ đọc qua.
        </p>

        <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href="/english-lab"
            class="inline-flex items-center justify-center rounded-2xl bg-teal-500 px-7 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-teal-600 hover:shadow-md"
          >
            Bắt đầu luyện tập
          </a>
          <a
            href="/blog"
            class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-7 py-3.5 text-base font-semibold text-slate-700 transition hover:bg-slate-50"
          >
            Đọc bài viết
          </a>
        </div>

        <!-- Stats row -->
        <div class="mt-14 grid grid-cols-3 gap-4 sm:gap-8">
          {[
            { number: '3', label: 'Kỳ thi được hỗ trợ' },
            { number: '60+', label: 'Câu dictation có sẵn' },
            { number: '100%', label: 'Miễn phí hoàn toàn' },
          ].map(stat => (
            <div class="rounded-2xl border border-slate-100 bg-slate-50 px-4 py-5">
              <p class="text-2xl font-extrabold text-teal-600 sm:text-3xl">{stat.number}</p>
              <p class="mt-1 text-xs font-medium text-slate-500 sm:text-sm">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Feature highlights ── -->
    <section class="bg-slate-50/60 px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-5xl">
        <div class="text-center">
          <p class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Công cụ học tập</p>
          <h2 class="mt-3 text-2xl font-extrabold text-slate-900 sm:text-3xl">Thiết kế để học được thật</h2>
          <p class="mt-3 text-base text-slate-500">Không phải chỉ đọc — bạn được thực hành ngay trên trình duyệt.</p>
        </div>

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">

          <!-- Flashcard -->
          <div class="flex flex-col rounded-[24px] border border-teal-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-teal-50 text-xl">🃏</div>
            <h3 class="mt-4 text-lg font-bold text-slate-900">Flashcard</h3>
            <p class="mt-2 flex-1 text-sm leading-7 text-slate-500">
              Lật card, đánh dấu đã thuộc hay chưa. Học từ vựng theo chủ đề mỗi ngày chỉ 5–10 phút.
            </p>
            <div class="mt-5 flex flex-col gap-2">
              <a href="/english-lab/toeic/flashcards" class="text-sm font-semibold text-teal-600 hover:text-teal-700">TOEIC Flashcards →</a>
              <a href="/english-lab/ielts/flashcards" class="text-sm font-semibold text-sky-600 hover:text-sky-700">IELTS Flashcards →</a>
              <a href="/english-lab/cambridge/flashcards" class="text-sm font-semibold text-emerald-600 hover:text-emerald-700">Cambridge Flashcards →</a>
            </div>
          </div>

          <!-- Dictation -->
          <div class="flex flex-col rounded-[24px] border border-sky-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-sky-50 text-xl">🎧</div>
            <h3 class="mt-4 text-lg font-bold text-slate-900">Dictation thông minh</h3>
            <p class="mt-2 flex-1 text-sm leading-7 text-slate-500">
              Nghe câu → gõ lại real-time → xem kết quả xanh/đỏ từng từ. Streak 🔥 khi đúng liên tiếp.
            </p>
            <div class="mt-5 flex flex-col gap-2">
              <a href="/english-lab/toeic/dictation" class="text-sm font-semibold text-teal-600 hover:text-teal-700">TOEIC Dictation →</a>
              <a href="/english-lab/ielts/dictation" class="text-sm font-semibold text-sky-600 hover:text-sky-700">IELTS Dictation →</a>
              <a href="/english-lab/cambridge/dictation" class="text-sm font-semibold text-emerald-600 hover:text-emerald-700">Cambridge Dictation →</a>
            </div>
          </div>

          <!-- Quiz coming soon -->
          <div class="flex flex-col rounded-[24px] border border-amber-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md sm:col-span-2 lg:col-span-1">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-amber-50 text-xl">📝</div>
            <div class="mt-4 flex items-center gap-2">
              <h3 class="text-lg font-bold text-slate-900">Thi thử có chấm điểm</h3>
              <span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-600">Sắp ra</span>
            </div>
            <p class="mt-2 flex-1 text-sm leading-7 text-slate-500">
              Đề thi thử TOEIC theo từng phần, chấm điểm tự động và hiện đáp án ngay sau khi nộp bài.
            </p>
            <p class="mt-5 text-sm font-semibold text-slate-300">Đang phát triển...</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ── English Lab cards ── -->
    <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-5xl">
        <div class="flex items-end justify-between">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Lộ trình</p>
            <h2 class="mt-3 text-2xl font-extrabold text-slate-900 sm:text-3xl">Chọn mục tiêu của bạn</h2>
            <p class="mt-2 text-base text-slate-500">Mỗi kỳ thi có nội dung và chiến lược học riêng.</p>
          </div>
          <a href="/english-lab" class="hidden text-sm font-semibold text-teal-600 hover:text-teal-700 sm:block">
            Xem tất cả →
          </a>
        </div>

        <div class="mt-10 grid gap-5 sm:grid-cols-3">

          <a href="/english-lab/toeic" class="group flex flex-col rounded-[24px] border border-teal-100 bg-gradient-to-br from-teal-50 to-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <div class="flex items-center justify-between">
              <p class="text-xs font-bold uppercase tracking-[0.25em] text-teal-600">TOEIC</p>
              <span class="rounded-full bg-teal-100 px-2.5 py-0.5 text-xs font-bold text-teal-600">B1 → B2</span>
            </div>
            <h3 class="mt-3 text-xl font-extrabold text-slate-900">Luyện nền tảng đi làm</h3>
            <p class="mt-2 flex-1 text-sm leading-6 text-slate-500">Từ vựng văn phòng, tài chính, nhân sự — thực tế và đúng trọng tâm.</p>
            <div class="mt-5 flex gap-2 text-xs font-semibold text-teal-600">
              <span class="rounded-full bg-teal-100 px-3 py-1">Flashcard</span>
              <span class="rounded-full bg-teal-100 px-3 py-1">Dictation</span>
            </div>
          </a>

          <a href="/english-lab/ielts" class="group flex flex-col rounded-[24px] border border-sky-100 bg-gradient-to-br from-sky-50 to-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <div class="flex items-center justify-between">
              <p class="text-xs font-bold uppercase tracking-[0.25em] text-sky-600">IELTS</p>
              <span class="rounded-full bg-sky-100 px-2.5 py-0.5 text-xs font-bold text-sky-600">B2 → C1</span>
            </div>
            <h3 class="mt-3 text-xl font-extrabold text-slate-900">Học theo từng kỹ năng</h3>
            <p class="mt-2 flex-1 text-sm leading-6 text-slate-500">Môi trường, giáo dục, sức khỏe — chủ đề hay gặp trong IELTS.</p>
            <div class="mt-5 flex gap-2 text-xs font-semibold text-sky-600">
              <span class="rounded-full bg-sky-100 px-3 py-1">Flashcard</span>
              <span class="rounded-full bg-sky-100 px-3 py-1">Dictation</span>
            </div>
          </a>

          <a href="/english-lab/cambridge" class="group flex flex-col rounded-[24px] border border-emerald-100 bg-gradient-to-br from-emerald-50 to-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <div class="flex items-center justify-between">
              <p class="text-xs font-bold uppercase tracking-[0.25em] text-emerald-600">Cambridge</p>
              <span class="rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-bold text-emerald-600">A2 → B1</span>
            </div>
            <h3 class="mt-3 text-xl font-extrabold text-slate-900">A2 + B1 rõ lộ trình</h3>
            <p class="mt-2 flex-1 text-sm leading-6 text-slate-500">Cuộc sống, du lịch, trường học — nền tảng vững cho người mới bắt đầu.</p>
            <div class="mt-5 flex gap-2 text-xs font-semibold text-emerald-600">
              <span class="rounded-full bg-emerald-100 px-3 py-1">Flashcard</span>
              <span class="rounded-full bg-emerald-100 px-3 py-1">Dictation</span>
            </div>
          </a>

        </div>

        <a href="/english-lab" class="mt-5 flex items-center justify-center text-sm font-semibold text-teal-600 hover:text-teal-700 sm:hidden">
          Xem tất cả →
        </a>
      </div>
    </section>

    <!-- ── Blog + Free resources ── -->
    <section class="bg-slate-50/60 px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-5xl">
        <div class="text-center">
          <p class="text-xs font-bold uppercase tracking-[0.25em] text-slate-400">Tài nguyên</p>
          <h2 class="mt-3 text-2xl font-extrabold text-slate-900 sm:text-3xl">Học thêm ngoài công cụ</h2>
          <p class="mt-2 text-base text-slate-500">Bài viết và tài liệu miễn phí để hỗ trợ quá trình học.</p>
        </div>

        <div class="mt-10 grid gap-5 sm:grid-cols-2">

          <a href="/blog" class="group flex flex-col rounded-[24px] border border-slate-100 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-slate-100 text-xl">✍️</div>
            <h3 class="mt-5 text-xl font-extrabold text-slate-900">Blog</h3>
            <p class="mt-2 flex-1 text-sm leading-7 text-slate-500">
              Ghi chú học, mẹo ngữ pháp và bài viết ngắn để đọc nhanh và áp dụng được ngay.
            </p>
            <p class="mt-5 text-sm font-semibold text-teal-600 group-hover:text-teal-700">Đọc bài viết →</p>
          </a>

          <a href="/free-resources" class="group flex flex-col rounded-[24px] border border-slate-100 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-slate-100 text-xl">📦</div>
            <h3 class="mt-5 text-xl font-extrabold text-slate-900">Tài liệu free</h3>
            <p class="mt-2 flex-1 text-sm leading-7 text-slate-500">
              Worksheet, checklist và file học được chọn lọc kỹ — tải về và dùng ngay không cần đăng ký.
            </p>
            <p class="mt-5 text-sm font-semibold text-sky-600 group-hover:text-sky-700">Xem tài liệu →</p>
          </a>

        </div>
      </div>
    </section>

    <!-- ── CTA bottom ── -->
    <section class="bg-white px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-3xl rounded-[28px] bg-gradient-to-br from-teal-500 to-teal-600 px-8 py-12 text-center shadow-lg">
        <span class="inline-flex rounded-full bg-teal-400/30 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-teal-100">
          Miễn phí · Không cần đăng ký
        </span>
        <h2 class="mt-4 text-2xl font-extrabold text-white sm:text-3xl">Sẵn sàng luyện tập chưa?</h2>
        <p class="mt-3 text-base text-teal-100">
          Chọn kỳ thi, chọn chủ đề và bắt đầu ngay — không cần cài gì thêm.
        </p>
        <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <a
            href="/english-lab/toeic/dictation"
            class="inline-flex items-center justify-center rounded-2xl bg-white px-7 py-3.5 text-base font-semibold text-teal-600 transition hover:bg-teal-50"
          >
            Thử Dictation ngay
          </a>
          <a
            href="/english-lab"
            class="inline-flex items-center justify-center rounded-2xl border border-teal-400 px-7 py-3.5 text-base font-semibold text-white transition hover:bg-teal-400/30"
          >
            Khám phá English Lab
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>
